<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<template id="report_progress_report">
			<t t-call="web.html_container">
				<t t-foreach="docs" t-as="o">
					<t t-call="web.external_layout">
						<div class="page">
							<h2>Progress Report 																																																
								<span t-field="o.name" />
							</h2>
							<p>Project: 																																				
								<span t-field="o.project_id" />
								<br />Date: 																																																
								<span t-field="o.date" />
								<t t-if="o.previous_progress_report_id">
									<br />Previous: 																																																						
									<span t-field="o.previous_progress_report_id" /> (									
									<span t-field="o.previous_progress_report_id.date" />)																																																					
								</t>
							</p>
							
							<table class="table table-sm o_main_table" name="progress_report_tasks_table">
								<thead>
									<tr>
										<th colspan="2">Task</th>
										<t t-if="o.previous_progress_report_id">
											<th>Previous</th>
										</t>
										<th>Current</th>
									</tr>
								</thead>
								<tbody>
									<t t-foreach="o._calculate_task_deltas()" t-as="task_delta">
										<t t-set="task" t-value="task_delta['task']" />
										<t t-set="previous" t-value="task_delta['previous']" />
										<t t-set="current" t-value="task_delta['current']" />
										<tr>
											<t t-if="previous">
												<td colspan="4"><span t-field="task.name" /></td>
											</t>
											<t t-if="not previous">
												<td colspan="3"><span t-field="task.name" /></td>
											</t>
										</tr>
										<tr>
											<td rowspan="5"><span t-field="task.description" /></td>
											<td>Qty.</td>
											<t t-if="previous">
												<td align="right"><span style="font-size:80%" t-field="previous.progress_quantity" /></td>
											</t>
											<td align="right"><span t-field="current.progress_quantity" /></td>
										</tr>
										<tr>
											<td>Unit</td>
											<t t-if="previous">
												<td align="right"><span style="font-size:80%" t-field="previous.progress_unit" /></td>
											</t>
											<td align="right"><span t-field="current.progress_unit" /></td>
										</tr>
										<tr>
											<td>Unit pr.</td>
											<t t-if="previous">
												<td align="right"><span style="font-size:80%" t-field="previous.progress_unit_price" /></td>
											</t>
											<td align="right"><span t-field="current.progress_unit_price" /></td>
										</tr>
										<tr>
											<td>Total pr.</td>
											<t t-if="previous">
												<td align="right"><span style="font-size:80%" t-field="previous.progress_total_price" /></td>
											</t>
											<td align="right"><span t-field="current.progress_total_price" /></td>
										</tr>
										<tr>
											<td>Progress</td>
											<t t-if="previous">
												<td align="right"><span style="font-size:80%" t-esc="'{} %'.format(previous.progress_percentage)" /></td>
											</t>
											<td align="right"><span t-esc="'{} %'.format(current.progress_percentage)" /></td>
										</tr>
										<tr>
											<t t-if="previous">
												<td colspan="3"></td>
											</t>
											<t t-if="not previous">
												<td colspan="2"></td>
											</t>											
											<td align="right"><strong><span t-field="current.progress_price" /></strong></td>
										</tr>
									</t>
								</tbody>
							</table>
						</div>
					</t>
				</t>
			</t>
		</template>
	</data>
</odoo>