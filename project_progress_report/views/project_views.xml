<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="view_project_kanban_inherit" model="ir.ui.view">
		<field name="name">project.project.kanban.inherit</field>
		<field name="model">project.project</field>
		<field name="inherit_id" ref="project.view_project_kanban"/>
		<field name="arch" type="xml">
			<xpath expr="//div[hasclass('o_project_kanban_boxes')]" position="inside">
				<a class="o_project_kanban_box" name="%(project.act_project_project_2_project_task_all)d" type="action">
					<div>
						<span class="o_value" t-if="record.progress_reports_count">
							<t t-esc="record.progress_reports_count.value"/>
						</span>
						<span class="o_value" t-if="not record.progress_reports_count">
							0
						</span>
						<span class="o_label">Progress reports</span>
					</div>
				</a>
			</xpath>
		</field>
	</record>

</odoo>