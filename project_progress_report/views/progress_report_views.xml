<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="project_progress_report_view_search" model="ir.ui.view">
		<field name="name">project.progress.report.search.form</field>
		<field name="model">project.progress.report</field>
		<field name="arch" type="xml">
			<search string="Tasks">
				<field name="name" string="Progress report"/>
				<field name="project_id"/>
				<separator/>
				<group expand="0" string="Group By">
					<filter string="Project" name="project" context="{'group_by': 'project_id'}"/>
					<filter string="Creation Date" name="group_create_date" context="{'group_by': 'create_date'}"/>
				</group>
			</search>
		</field>
	</record>

	<record id="project_progress_report_view_tree" model="ir.ui.view">
		<field name="name">project.progress.report.tree</field>
		<field name="model">project.progress.report</field>
		<field eval="2" name="priority"/>
		<field name="arch" type="xml">
			<tree string="Progress reports" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
				<field name="name"/>
				<field name="project_id" optional="show"/>
				<field name="date" />
				<field name="state" />
			</tree>
		</field>
	</record>

	<record id="project_progress_report_view_form" model="ir.ui.view">
		<field name="name">project.progress.report.form</field>
		<field name="model">project.progress.report</field>
		<field name="priority" eval="2" />
		<field name="arch" type="xml">
			<form string="Progress report">
				<header>
					<button name="update_task_progress" string="Update task progress" type="object" class="oe_highlight" attrs="{'invisible' : [('state', '!=', 'draft')]}"/>
					<button name="post" string="Post" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
					<field name="state" widget="statusbar" options="{'clickable': '0'}"/>
				</header>
				<sheet string="Progress report">
					<div class="oe_title">
						<h1>
							<field name="name" />
						</h1>
					</div>
					<group>
						<group>
							<field name="project_id" />
						</group>
						<group>
							<field name="date" />
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_project_project_2_project_progress_reports" model="ir.actions.act_window">
		<field name="name">Progress reports</field>
		<field name="res_model">project.progress.report</field>
		<field name="view_mode">tree,form</field>
		<field name="context">{
                'search_default_project_id': [active_id],
                'default_project_id': active_id,
            }</field>
		<field name="search_view_id" ref="project_progress_report_view_search"/>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
                    Create a new progress report
			</p>
			<p>
                    Progress reports allow you to create a financial overview of the project progress at any given moment, compared to a previous state.
			</p>
		</field>
	</record>

	<record id="action_progress_report_list" model="ir.actions.act_window">
		<field name="name">Progress reports</field>
		<field name="res_model">project.progress.report</field>
		<field name="view_mode">tree,form</field>
		<!-- <field name="context">{'search_default_my_tasks': 1}</field> -->
		<field name="search_view_id" ref="project_progress_report_view_search"/>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
                    Create a new progress report
			</p>
			<p>
                    Progress reports allow you to create a financial overview of the project progress at any given moment, compared to a previous state.
			</p>
		</field>
	</record>

	<menuitem name="Progress reports" id="menu_progress_reports" parent="project.menu_main_pm" action="action_progress_report_list" sequence="3" groups="base.group_no_one,project.group_project_user"/>

</odoo>