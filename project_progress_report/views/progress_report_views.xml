	<record id="action_progress_report_list" model="ir.actions.act_window">
		<field name="name">Progress reports</field>
		<field name="res_model">project.progress.report</field>
		<field name="view_mode">tree,form</field>
		<!-- <field name="context">{'search_default_my_tasks': 1}</field> -->
		<!-- <field name="search_view_id" ref="view_task_search_form"/> -->
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
                    Create a new progress report
			</p>
			<p>
                    Progress reports allow you to create a financial overview of the project progress at any given moment, compared to a previous state.
			</p>
		</field>
	</record>

	<record id="open_view_task_list_tree" model="ir.actions.act_window.view">
		<field name="sequence" eval="1"/>
		<field name="view_mode">tree</field>
		<field name="act_window_id" ref="action_progress_report_list"/>
	</record>

	<menuitem name="Progress reports" id="menu_progress_reports" parent="project.menu_main_pm" action="action_progress_report_list" sequence="3" groups="base.group_no_one,project.group_project_user"/>

</odoo>