<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="project_progress_report_view_tree" model="ir.ui.view">
		<field name="name">project.progress.report.tree</field>
		<field name="model">project.progress.report</field>
		<field eval="2" name="priority"/>
		<field name="arch" type="xml">
			<tree string="Progress reports">
				<field name="name"/>
				<field name="project_id" optional="show"/>
				<field name="date" />
				<field name="state" />
			</tree>
		</field>
	</record>

	<record id="project_progress_report_view_form" model="ir.ui.view">
		<field name="name">project.progress.report.form</field>
		<field name="model">project.progress.report</field>
		<field name="priority" eval="2" />
		<field name="arch" type="xml">
			<form string="Progress report">
				<sheet string="Progress report">
					<div class="oe_title">
						<h1>
							<field name="name" />
						</h1>
					</div>
				</sheet>
			</form>
		</field>
	</record>

