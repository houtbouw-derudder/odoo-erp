<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record model="ir.ui.view" id="view_task_form2_inherited">
		<field name="name">project.task.form.inherited</field>
		<field name="model">project.task</field>
		<field name="inherit_id" ref="project.view_task_form2" />
		<!-- <field name="groups_id" eval="[(6,0, (ref('hr_timesheet.group_hr_timesheet_user'),))]"/> -->
		<field name="arch" type="xml">
			<xpath expr="//notebook/page[@name='description_page']" position="after">
				<field name="include_in_progress_report" invisible="1" />
				<page string="Progress" id="progress_tab" attrs="{'invisible': [('include_in_progress_report', '=', False)]}">
					<group>
						<group>
							<field name="sale_quantity" />
							<field name="sale_unit" />
						</group>
						<group>
							<field name="sale_currency_id" invisible="1" />
							<field name="sale_unit_price" widget="monetary" options="{'currency_field': 'sale_currency_id', 'field_digits': True}"/>
							<field name="total_sale_price" widget="monetary" options="{'currency_field': 'sale_currency_id', 'field_digits': True}" />
						</group>
					</group>
					<group>
						<group>
							<field name="progress" widget="percentage" />
							<field name="progress" />
						</group>
					</group>
				</page>
			</xpath>
		</field>
	</record>
</odoo>