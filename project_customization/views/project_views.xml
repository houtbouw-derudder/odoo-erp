<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_project_kanban_inherited" model="ir.ui.view">
		<field name="name">project.project.customization.kanban.inherited</field>
		<field name="model">project.project</field>
		<field name="inherit_id" ref="project.view_project_kanban"/>
		<field name="priority">24</field>
		<field name="arch" type="xml">
			<xpath expr="//div[hasclass('o_project_kanban_boxes')]" position="inside">
				<a t-if="record.analytic_account_id.raw_value" class="o_project_kanban_box o_project_timesheet_box" name="action_view_account_analytic_line_2" type="object" groups="analytic.group_analytic_accounting">
					<div>
						<span class="o_label">Profitability</span>
					</div>
				</a>
			</xpath>
		</field>
	</record>
</odoo>